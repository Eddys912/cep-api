			"PaymentResult": {
				"properties": {
					"success": {
						"type": "boolean"
					},
					"message": {
						"type": "string"
					},
					"internalMessage": {
						"type": "string"
					},
					"claveRastreo": {
						"type": "string"
					},
					"monto": {
						"type": "number",
						"format": "double"
