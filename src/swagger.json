				"type": "object",
				"additionalProperties": false
			},
			"CepTypeStatus": {
				"description": "Status types for CEP processing jobs",
				"enum": [
					"pending",
					"processing",
					"completed",
					"failed"
				],
				"type": "string"
			},
			"CepResponse": {
				"description": "Response for CEP generation request",
				"properties": {
					"cep_id": {
						"type": "string"
					},
					"message": {
						"type": "string"
					},
					"status": {
