						"type": "string"
					},
					"nombreBeneficiario": {
						"type": "string"
					},
					"tipoCuentaBeneficiario": {
						"type": "string"
					},
					"cuentaBeneficiario": {
						"type": "string"
					},
					"nombreBeneficiario2": {
						"type": "string"
					},
					"tipoCuentaBeneficiario2": {
						"type": "string"
					},
					"cuentaBeneficiario2": {
						"type": "string"
					},
					"rfcCurpBeneficiario": {
						"type": "string"
					},
					"conceptoPago": {
						"type": "string"
					},
					"referenciaNumerica": {
						"type": "string"
					},
					"empresa": {
						"type": "string"
