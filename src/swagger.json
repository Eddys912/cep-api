	"paths": {
		"/webhook/dzog-capital/payments": {
			"post": {
				"operationId": "ProcessDzogPayment",
				"responses": {
					"200": {
						"description": "Payment processed",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/WebhookResponse"
								}
							}
						}
					},
					"400": {
						"description": "Invalid payload"
					},
					"500": {
						"description": "Processing error"
					}
				},
				"description": "Receives STP payments for Dzog Capital and routes to the appropriate processor.",
				"summary": "Process STP Payment (Dzog Capital)",
				"tags": [
					"STP Webhooks"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/StpPayload"
							}
						}
					}
				}
			}
		},
		"/webhook/aplicarPago": {
			"post": {
				"operationId": "ProcessStpPayment",
				"responses": {
					"200": {
						"description": "Payment applied",
						"content": {
							"application/json": {
								"schema": {
									"allOf": [
										{
											"$ref": "#/components/schemas/PaymentResult"
										},
										{
											"properties": {
												"processingTimeMs": {
													"type": "number",
													"format": "double"
												}
											},
											"required": [
												"processingTimeMs"
											],
											"type": "object"
										}
									]
								}
							}
						}
					},
					"400": {
						"description": "Invalid payload"
					},
					"500": {
						"description": "Processing error"
					}
				},
				"description": "Receives STP payments for Sozu and applies payment through the Sozu pipeline.",
				"summary": "Process STP Payment (Sozu)",
				"tags": [
					"STP Webhooks"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/StpPayload"
							}
						}
					}
				}
			}
		},
