{
  "name": "server-stp",
  "version": "1.0.0",
  "description": "Servicio para la gestión de pagos de STP y obtención de CEPs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "pnpm run tsoa && concurrently --raw \"pnpm run swagger:watch\" \"pnpm run serve:dev\"",
    "serve:dev": "tsx watch --ignore src/swagger.json src/server.ts",
    "swagger:watch": "nodemon -e ts -w src/controllers -w src/types -x \"pnpm run tsoa\"",
    "build": "rimraf dist && pnpm run tsoa && tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "tsoa": "tsoa spec-and-routes",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,json,md}\""
  },
  "keywords": [
    "cep",
    "banxico",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@supabase/supabase-js": "2.105.1",
    "@tsoa/runtime": "6.1.1",
    "axios": "1.15.2",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.4.1",
    "helmet": "8.1.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "swagger-ui-express": "5.0.1",
    "tsoa": "6.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/supertest": "7.2.0",
    "@types/swagger-ui-express": "4.1.8",
    "@vitest/coverage-v8": "4.1.5",
    "concurrently": "9.2.1",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "nodemon": "3.1.14",
    "pino-pretty": "13.1.3",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "supertest": "7.2.2",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  }
}
